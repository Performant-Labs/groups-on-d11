# .agents/pr-review.yml
# PR Reviewer configuration for this project.
# Generated by setup-pr-review.sh — re-run to update.
#
# All feature flags default to false unless the wizard detected the
# prerequisite and you opted in. See playbook/pipelines/pr-reviewer/
# for the canonical scripts and workflow templates.

project:
  name: ""                        # shown in review footers
  timezone: "America/Los_Angeles" # used for timestamp formatting

# ── CI review via PR-Agent (DeepSeek V4) ───────────────────────────────────
# Requires: GitHub remote, DEEPSEEK_API_KEY secret in GitHub Actions.
pr_agent:
  enabled: false
  model: "deepseek/deepseek-v4-pro"
  max_tokens: 131072
  output_tokens: 64000
  high_stakes_label: "high-stakes"  # PRs with this label get a deeper review job
  skip_docs_only: false             # skip review when PR only touches docs/planning files
  score_labels: true                # apply score-90+/80-89/70-79/below-70 labels
  score_banner: true                # inject score summary banner into PR description
  status_check: true                # post a green/red commit status after review
  cancel_in_flight: true            # cancel running review when a new commit is pushed

# ── Local review via `claude -p` ───────────────────────────────────────────
# Requires: claude CLI authenticated, gh CLI authenticated.
local_review:
  enabled: false
  default_model: "claude-sonnet-4-6"  # override with --model flag or $REVIEWER_MODEL
  shell_alias: ""                      # e.g. "pr:review" — empty means no alias created

# ── O3 dual-review (independent architecture gate) ─────────────────────────
# Requires: OPENAI_API_KEY in environment.
# Fires at Phase 4 (brief) and/or Phase 7 (implementation) of the implement loop.
dual_review:
  enabled: false
  model: "o3"
  on_brief: true   # review the task brief before implementation starts
  on_impl: true    # review the implementation against the brief

# ── DCO sign-off enforcement ───────────────────────────────────────────────
# Requires: GitHub remote.
# Adds a separate dco.yml GitHub Actions workflow.
dco:
  enabled: false

# ── PR body template ───────────────────────────────────────────────────────
# Installs .github/pull_request_template.md with acceptance-criteria checklist.
pr_template:
  enabled: false

# ── Test tier verification hierarchy ──────────────────────────────────────
# Requires: Playwright (t2 and above).
# Controls which tiers the test-writer agent is expected to produce.
test_tiers:
  t1_headless: true        # HTTP codes, response headers, HTML elements via curl/inject
  t2_aria: false           # ARIA accessibility tree (Playwright, unauthenticated routes)
  t2_5_authenticated: false # ARIA tree for authenticated routes (CDP harness or auth fixture)
  t3_visual: false          # screenshot sign-off per design slice (Playwright screenshots)
