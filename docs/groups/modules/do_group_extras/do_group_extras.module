<?php

/**
 * @file
 * Archive enforcement, submission guidelines, and moderation defaults for groups.
 */

use Drupal\Core\Access\AccessResult;
use Drupal\Core\Form\FormStateInterface;
use Drupal\group\Entity\GroupInterface;
use Drupal\node\NodeInterface;

/**
 * Implements hook_form_alter().
 *
 * Adds submission guidelines to group create/edit forms and blocks content
 * creation forms in archived groups.
 */
function do_group_extras_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  // Add submission guidelines to group create/edit forms.
  if (strpos($form_id, 'group_community_group') !== FALSE) {
    $form['submission_guidelines'] = [
      '#type' => 'details',
      '#title' => t('Submission Guidelines'),
      '#open' => TRUE,
      '#weight' => -100,
      '#markup' => t('<p>Please review community guidelines before creating a group. All new groups created by non-administrators require moderator approval before they become visible.</p>'),
    ];
  }
}

/**
 * Implements hook_entity_presave().
 *
 * Non-admin group creation defaults to unpublished (requires moderation).
 */
function do_group_extras_entity_presave($entity) {
  if (!($entity instanceof GroupInterface)) {
    return;
  }

  // Only act on new groups.
  if (!$entity->isNew()) {
    return;
  }

  // Skip if created by administrators/site moderators.
  $account = \Drupal::currentUser();
  if ($account->hasPermission('administer group') || $account->hasPermission('administer groups')) {
    return;
  }

  // Default to unpublished — requires site_moderator approval.
  $entity->set('status', 0);
}

/**
 * Implements hook_entity_insert().
 *
 * Queues a notification when a new group is pending approval.
 */
function do_group_extras_entity_insert($entity) {
  if (!($entity instanceof GroupInterface)) {
    return;
  }

  // If the group is unpublished (pending), queue a notification.
  if (!$entity->isPublished()) {
    _do_group_extras_notify_moderators($entity);
  }
}

/**
 * Notifies site_moderator users about a pending group.
 *
 * This only records to a queue — actual email delivery is handled
 * by an external system.
 */
function _do_group_extras_notify_moderators(GroupInterface $group) {
  $queue = \Drupal::queue('do_group_extras_pending_notification');
  $queue->createItem([
    'group_id' => $group->id(),
    'group_label' => $group->label(),
    'author_uid' => $group->getOwnerId(),
    'timestamp' => \Drupal::time()->getRequestTime(),
  ]);
  \Drupal::logger('do_group_extras')->notice(
    'Pending group notification queued for group %label (gid=%gid)',
    ['%label' => $group->label(), '%gid' => $group->id()]
  );
}

/**
 * Implements hook_preprocess_group().
 *
 * Adds "Archived" badge to archived groups and attaches CSS library.
 */
function do_group_extras_preprocess_group(array &$variables) {
  /** @var \Drupal\group\Entity\GroupInterface $group */
  $group = $variables['group'];

  if (!$group->hasField('field_group_type')) {
    return;
  }

  $group_type_ref = $group->get('field_group_type')->entity;
  if ($group_type_ref && $group_type_ref->getName() === 'Archive') {
    $variables['attributes']['class'][] = 'group--archived';
    $variables['archived'] = TRUE;
    $variables['#attached']['library'][] = 'do_group_extras/do_group_extras';
  }
}

/**
 * Implements hook_node_access().
 *
 * Denies content creation in archived groups.
 */
function do_group_extras_node_access(NodeInterface $node, $op, $account) {
  if ($op !== 'create') {
    return AccessResult::neutral();
  }

  // Check if we're in a group context.
  $route_match = \Drupal::routeMatch();
  $group = $route_match->getParameter('group');

  if (!($group instanceof GroupInterface)) {
    return AccessResult::neutral();
  }

  if (!$group->hasField('field_group_type')) {
    return AccessResult::neutral();
  }

  $group_type_ref = $group->get('field_group_type')->entity;
  if ($group_type_ref && $group_type_ref->getName() === 'Archive') {
    return AccessResult::forbidden('This group is archived. No new content can be created.')
      ->addCacheableDependency($group);
  }

  return AccessResult::neutral();
}
