<?php

/**
 * @file
 * Hot content scoring, Views integration, and new-node seeding.
 */

use Drupal\node\NodeInterface;

/**
 * Implements hook_cron().
 *
 * Recomputes hot scores for nodes changed in the last 7 days.
 * Score = (comment_count × 3) + (view_count × 0.5)
 */
function do_discovery_cron() {
  $database = \Drupal::database();

  // Bail out if required tables do not exist.
  if (!$database->schema()->tableExists('do_discovery_hot_score')) {
    return;
  }

  $cutoff = \Drupal::time()->getRequestTime() - (7 * 86400);

  // Build query to compute scores for recently changed nodes.
  $query = $database->select('node_field_data', 'n');
  $query->fields('n', ['nid']);
  $query->condition('n.status', 1);
  $query->condition('n.changed', $cutoff, '>=');

  // LEFT JOIN comment statistics for comment counts.
  $query->leftJoin('comment_entity_statistics', 'ces', 'ces.entity_id = n.nid AND ces.entity_type = :node_type', [':node_type' => 'node']);
  $query->addExpression('COALESCE(ces.comment_count, 0)', 'comment_count');

  // LEFT JOIN statistics node_counter for view counts.
  if ($database->schema()->tableExists('node_counter')) {
    $query->leftJoin('node_counter', 'nc', 'nc.nid = n.nid');
    $query->addExpression('COALESCE(nc.totalcount, 0)', 'view_count');
  }
  else {
    $query->addExpression('0', 'view_count');
  }

  $results = $query->execute();

  $now = \Drupal::time()->getRequestTime();

  foreach ($results as $row) {
    $score = ($row->comment_count * 3) + ($row->view_count * 0.5);

    $database->merge('do_discovery_hot_score')
      ->key('nid', $row->nid)
      ->fields([
        'score' => $score,
        'computed' => $now,
      ])
      ->execute();
  }
}

/**
 * Implements hook_views_data().
 *
 * Exposes do_discovery_hot_score table to Views.
 */
function do_discovery_views_data() {
  $data['do_discovery_hot_score'] = [
    'table' => [
      'group' => t('Hot Content'),
      'provider' => 'do_discovery',
      'join' => [
        'node_field_data' => [
          'left_field' => 'nid',
          'field' => 'nid',
        ],
      ],
    ],
    'nid' => [
      'title' => t('Node ID'),
      'help' => t('The node ID with a hot score.'),
      'field' => [
        'id' => 'numeric',
      ],
      'filter' => [
        'id' => 'numeric',
      ],
      'sort' => [
        'id' => 'standard',
      ],
      'relationship' => [
        'title' => t('Scored Content'),
        'help' => t('Relate hot score to the node.'),
        'base' => 'node_field_data',
        'base field' => 'nid',
        'id' => 'standard',
        'label' => t('Node'),
      ],
    ],
    'score' => [
      'title' => t('Hot Score'),
      'help' => t('The computed hot content score.'),
      'field' => [
        'id' => 'numeric',
      ],
      'filter' => [
        'id' => 'numeric',
      ],
      'sort' => [
        'id' => 'standard',
      ],
    ],
    'computed' => [
      'title' => t('Score Computed'),
      'help' => t('When the hot score was last computed.'),
      'field' => [
        'id' => 'date',
      ],
      'filter' => [
        'id' => 'date',
      ],
      'sort' => [
        'id' => 'date',
      ],
    ],
  ];

  return $data;
}

/**
 * Implements hook_node_insert().
 *
 * Seeds a score = 0 row so new published nodes appear in hot content Views.
 */
function do_discovery_node_insert(NodeInterface $node) {
  if (!$node->isPublished()) {
    return;
  }

  $database = \Drupal::database();
  if (!$database->schema()->tableExists('do_discovery_hot_score')) {
    return;
  }

  $database->merge('do_discovery_hot_score')
    ->key('nid', $node->id())
    ->fields([
      'score' => 0,
      'computed' => \Drupal::time()->getRequestTime(),
    ])
    ->execute();
}
