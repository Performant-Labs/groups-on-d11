<?php

/**
 * @file
 * Contribution stats and profile completeness blocks.
 */

/**
 * Implements hook_theme().
 */
function do_profile_stats_theme($existing, $type, $theme, $path) {
  return [
    'do_contribution_stats' => [
      'variables' => [
        'topics' => 0,
        'events' => 0,
        'comments' => 0,
        'groups' => 0,
        'days_active' => 0,
      ],
      'template' => 'pl-contribution-stats',
    ],
    'do_profile_completeness' => [
      'variables' => [
        'percentage' => 0,
        'missing_fields' => [],
      ],
      'template' => 'pl-profile-completeness',
    ],
  ];
}

/**
 * Implements hook_page_attachments().
 */
function do_profile_stats_page_attachments(array &$attachments) {
  $route = \Drupal::routeMatch()->getRouteName();
  if ($route === 'entity.user.canonical') {
    $attachments['#attached']['library'][] = 'do_profile_stats/do_profile_stats';
  }
}
