<div class="pl-contribution-stats">
  <div class="stats-grid">
    <div class="stat-item">
      <span class="stat-value">{{ topics }}</span>
      <span class="stat-label">{{ 'Forum Topics'|t }}</span>
    </div>
    <div class="stat-item">
      <span class="stat-value">{{ events }}</span>
      <span class="stat-label">{{ 'Events'|t }}</span>
    </div>
    <div class="stat-item">
      <span class="stat-value">{{ comments }}</span>
      <span class="stat-label">{{ 'Comments'|t }}</span>
    </div>
    <div class="stat-item">
      <span class="stat-value">{{ groups }}</span>
      <span class="stat-label">{{ 'Groups'|t }}</span>
    </div>
    <div class="stat-item">
      <span class="stat-value">{{ days_active }}</span>
      <span class="stat-label">{{ 'Days Active'|t }}</span>
    </div>
  </div>
</div>
