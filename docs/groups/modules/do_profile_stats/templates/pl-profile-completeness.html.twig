<div class="pl-profile-completeness">
  <h3>{{ 'Profile Completeness'|t }}: {{ percentage }}%</h3>
  <div class="progress-bar">
    <div class="progress-fill" style="width: {{ percentage }}%;"></div>
  </div>
  {% if missing_fields|length > 0 %}
    <p>{{ 'Complete your profile by adding:'|t }}</p>
    <ul class="missing-fields">
      {% for field in missing_fields %}
        <li>{{ field }}</li>
      {% endfor %}
    </ul>
  {% else %}
    <p class="complete-message">{{ 'Your profile is complete!'|t }}</p>
  {% endif %}
</div>
