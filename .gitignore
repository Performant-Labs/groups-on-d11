# Drupal .gitignore — standard for drupal/recommended-project
# composer.lock is intentionally tracked for reproducible installs.

# Composer-managed directories (restored via: composer install)
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/libraries/

# Drupal scaffold files placed by composer (not custom, regenerated)
/web/sites/default/default.settings.php
/web/sites/default/default.services.yml

# Runtime / environment-specific
/web/sites/default/files/
/web/sites/default/settings.php
/web/sites/default/settings.local.php
/web/sites/default/services.yml

# DB backups — do not commit binary blobs
/backups/

# OS / editor noise
.DS_Store
*.swp
*.swo
.vscode/

# Node / Playwright — installed at build time; the runnable artifact (Docker image)
# is built on Uranus (ghcr.io/performant-labs/groups-on-d11), so keep the repo source-only.
node_modules/
/test-results/
/playwright-report/
/playwright/.cache/

# Local Claude Code worktrees/state
.claude/

# Local secrets (pipeline review keys) — never commit
.env
